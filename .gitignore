# ─────────────────────────────────────────────
#  UHostel — Root .gitignore
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
**/node_modules/

# ── Environment Variables ─────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Build Outputs ─────────────────────────────
dist/
build/
out/
.output/

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Runtime & Cache ───────────────────────────
.cache/
.parcel-cache/
.vite/
*.tsbuildinfo

# ── IDE & Editor ──────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS Files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Testing ───────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────
*.local
*.pid
*.seed
*.pid.lock
.yarn-integrity
