# ─────────────────────────────────────────────
#  Backend Environment Variables — .env.example
#  Copy this file to .env and fill in your values
#  DO NOT commit .env to version control
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5001

# MongoDB
MONGO_URI=mongodb://localhost:27017/uhostel
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/uhostel

# JWT
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# SMTP — for OTP email delivery
# Use Gmail App Password (not your main password)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password

# Frontend URL (used for CORS)
CLIENT_URL=http://localhost:5173
